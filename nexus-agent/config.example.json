{
  "jira": {
    "baseUrl": "https://your-org.atlassian.net",
    "email": "you@example.com",
    "apiToken": "YOUR_JIRA_API_TOKEN",
    "label": "your-trigger-label",
    "labelProcessed": "your-done-label",
    "maxComments": 100,
    "fields": {
      "affectedSystems": "customfield_10056",
      "fixVersions": "fixVersions"
    }
  },
  "azureDevOps": {
    "org": "https://dev.azure.com/YOUR_ORG",
    "project": "YOUR_PROJECT",
    "repoBaseUrl": "git@ssh.dev.azure.com:v3/YOUR_ORG/YOUR_PROJECT",
    "pat": "YOUR_AZURE_DEVOPS_PAT",
    "patEnvVar": "AZURE_DEVOPS_PAT"
  },
  "services": {
    "my-service": {
      "repo": "my-service",
      "component": "Component Name",
      "componentId": "12345",
      "lead": "Team Lead Name"
    }
  },
  "slack": {
    "botToken": "xoxb-YOUR-SLACK-BOT-TOKEN",
    "userId": "UXXXXXXXXXX"
  },
  "agent": {
    "pollInterval": 300,
    "maxTicketsPerCycle": 1,
    "logDir": "./logs",
    "executionRetries": 1
  },
  "aiProvider": {
    "strategy": "single",

    "execute": {
      "provider": "claude",
      "fallbackProvider": null,
      "claude": {
        "model": "haiku",
        "maxTurns": 30,
        "timeoutMinutes": 15,
        "allowedTools": "Read,Write,Edit,Bash,Glob,Grep"
      },
      "codex": {
        "model": null,
        "timeoutMinutes": 15
      }
    }
  },
  "council": {
    "maxRounds": 3,
    "proposer": {
      "provider": "claude",
      "model": "sonnet",
      "maxTurns": 15,
      "timeoutMinutes": 10,
      "allowedTools": "Read,Glob,Grep"
    },
    "critics": [
      {
        "provider": "claude",
        "model": "sonnet",
        "maxTurns": 15,
        "timeoutMinutes": 10,
        "allowedTools": "Read,Glob,Grep"
      }
    ],
    "evaluator": {
      "provider": "claude",
      "model": "sonnet",
      "maxTurns": 5,
      "timeoutMinutes": 5,
      "allowedTools": "Read,Glob,Grep"
    }
  },
  "prReviewCouncil": {
    "maxRounds": 2,
    "proposer": {
      "provider": "claude",
      "model": "sonnet",
      "maxTurns": 10,
      "timeoutMinutes": 8,
      "allowedTools": "Read,Glob,Grep"
    },
    "critics": [
      {
        "provider": "claude",
        "model": "sonnet",
        "maxTurns": 10,
        "timeoutMinutes": 8,
        "allowedTools": "Read,Glob,Grep"
      }
    ],
    "evaluator": {
      "provider": "claude",
      "model": "sonnet",
      "maxTurns": 5,
      "timeoutMinutes": 5,
      "allowedTools": "Read,Glob,Grep"
    }
  },
  "infra": {
    "enabled": false,
    "scriptsDir": "/path/to/infra-scripts",
    "stopAfterProcessing": false
  },
  "tests": {
    "enabled": false
  },
  "sentry": {
    "authToken": "YOUR_SENTRY_AUTH_TOKEN",
    "baseUrl": "https://sentry.example.com",
    "orgSlug": "your-org",
    "pollInterval": 300,
    "stateDir": ".sentry-state",
    "services": {
      "my-service": {
        "projectSlug": "my-service",
        "jiraProject": "JCP",
        "environments": ["production"],
        "minLevel": "error",
        "issueStatus": "unresolved",
        "limit": 25
      }
    }
  }
}
